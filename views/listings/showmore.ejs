<% layout("/layouts/boilerplate") %>
<body>

<div class="row mt-1">   
    <div class="col-8 offset-2 ">
       
        <h3><%=list.title %></h3>
    </div>

    <div class="col-6 offset-2">
        <div class="card listing-card">
            <img src="<%=list.image %>" class="card-img-top show-img" alt="image">
            <div class="card-body">
                <p class="card-text "><i>owned by<%=list.owner.username%></i></p>
                    
                    <p><%=list.description %></p>
                    <p>&#8377; <%= (list.price ?? 0).toLocaleString("en-IN") %></p>
                    <p><%=list.location%></p>
                    <p><%=list.country %></p> 


                
            </div>
        </div>

    </div>
    
    <div class="btns">
        <% if(currentUser && currentUser._id.equals(list.owner._id)){%>

        <a href="/listings/<%=list._id%>/edit" class="btn btn-dark btn-color col-1 offset-2 ">Edit</a>

        <form method="post" action="/listings/<%= list._id %>/delete?_method=delete">
            <button class="btn btn-dark offset-2  ">delete</button>
        </form>

       <% } %>
        
          
    </div>

   

    <div class="col-8 offset-2 ">
        <hr/>
        <% if(currentUser){ %>
        <h4>leave a Review</h4>
        <form method="post" action="/listings/<%=list._id%>/reviews" novalidate class="needs-validation" >
            <!-- <div class="mt-2 mb-2">
                
                <input type="range" min="1" max="5" id="rating" class="form-range" required name="review[rating]">
                <div class="invalid-feedback">enter the rating</div>
            </div> -->
             <div class="mt-2 mb-2">
                <label for="rating" class="form-label"  >rating</label>
            <fieldset class="starability-slot">
            
            <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
            <input type="radio" id="first-rate1" name="review[rating]" value="1" />
            <label for="first-rate1" title="Terrible">1 star</label>
            <input type="radio" id="first-rate2" name="review[rating]" value="2" />
            <label for="first-rate2" title="Not good">2 stars</label>
            <input type="radio" id="first-rate3" name="review[rating]" value="3" />
            <label for="first-rate3" title="Average">3 stars</label>
            <input type="radio" id="first-rate4" name="review[rating]" value="4" />
            <label for="first-rate4" title="Very good">4 stars</label>
            <input type="radio" id="first-rate5" name="review[rating]" value="5" />
            <label for="first-rate5" title="Amazing">5 stars</label>
            </fieldset>
            
            </div>
            

            <div class="mt-2 mb-2">
            <label for="comment" class="form-label" >comment</label>
            <textarea name="review[comment]" id="comment" required class="form-control" cols="30" rows="5"></textarea>
            <div class="invalid-feedback">enter the valid comment</div>
            </div>

            <button class="btn btn-dark">submit</button>
        </form>

        <%} %>
    </div>

    
    <div class="col-8 offset-2 ">
        <hr/>
        <h4> all reviews :</h4>
        <div class="row">
             <% for( review of list.reviews){%>
                
                <div class="card review-card col-5 ms-3 mb-3">
                    <div class="card-body">
                        <h5 class="crad-title"><%= review.author.username%></h5>
                        <p class="starability-result card-text" data-rating="<%= review.rating%>"></p>
                        <p class="card-text"><%= review.comment%> </p> <br>

                         
                         
                          
                    </div>

                     <div>
                        <% if(review.author.equals(currentUser && currentUser._id)){ %>
                                
                        <form method="post" action="/listings/<%=list._id%>/reviews/<%=review._id%>/delete?_method=Delete">
                            
                            <button class="btn btn-dark mb-3">Delete</button>
                        </form>
                       <% } %>
                   </div>
                </div>
                
                        
                    
                
        <%}%>
        </div>
        
        

    </div>
           




   
</div>      
</body>



    

<!-- ======= LISTINGS ======= -->
<div class="listings-section">
  <div class="section-header">
    <h2 class="section-title">All Listings</h2>
    <span class="section-count"><%= allListings.length %> places to stay</span>
  </div>

  <div class="listings-grid">
    <% if (allListings.length === 0) { %>
      <div class="empty-state">
        <div class="empty-icon">🏙️</div>
        <h3>No listings yet</h3>
        <p>Be the first to add an amazing place!</p>
      </div>
    <% } %>

    <% for(let listing of allListings) { %>
      <a href="/listings/<%= listing._id %>/show" class="listing-card-link">
        <div class="listing-card">

          <!-- Image -->
          <div class="card-image-wrapper">
            <img
              src="<%= listing.image %>"
              alt="<%= listing.title %>"
              loading="lazy"
              onerror="this.src='https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=600&auto=format&fit=crop'"
            />

            <!-- Wishlist heart -->
            <button class="wishlist-btn" onclick="toggleWish(event, this)" aria-label="Save to wishlist">
              <svg viewBox="0 0 24 24">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
              </svg>
            </button>

            <!-- Rating -->
            <% const rating = (4.5 + Math.random() * 0.5).toFixed(2); %>
            <div class="rating-badge">
              <svg viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              <%= rating %>
            </div>
          </div>

          <!-- Body -->
          <div class="card-body">
            <div class="card-location">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
              <% const countries = ["India", "France", "Japan", "Italy", "Spain", "UK", "Thailand", "Maldives", "Greece"]; %>
              <% const country = countries[Math.floor(Math.random() * countries.length)]; %>
              <%= country %>
            </div>

            <h3 class="card-title"><%= listing.title %></h3>
            <p class="card-distance"><%= Math.floor(1000 + Math.random() * 9000).toLocaleString() %> kilometres away</p>

            <div class="card-footer">
              <div class="card-price">
                <span class="price-amount">&#8377;<%= (listing.price ?? 0).toLocaleString("en-IN") %></span>
                <span class="price-unit">/ night</span>
              </div>
              <span class="card-tag">Available</span>
            </div>
          </div>

        </div>
      </a>
    <% } %>
  </div>
</div>

<!-- ======= SCRIPTS ======= -->
<script>
  // Wishlist toggle
  function toggleWish(e, btn) {
    e.preventDefault();
    e.stopPropagation();
    btn.classList.toggle('liked');
  }

  // Category active state from URL
  (function() {
    const params = new URLSearchParams(window.location.search);
    const cat = params.get('category') || 'all';
    document.querySelectorAll('.category-item').forEach(item => {
      item.classList.remove('active');
      const href = new URL(item.href, location.origin);
      if ((href.searchParams.get('category') || 'all') === cat) {
        item.classList.add('active');
      }
    });
  })();

  // Lazy image shimmer
  document.querySelectorAll('.card-image-wrapper img').forEach(img => {
    img.addEventListener('load', () => img.style.opacity = '1');
    img.style.opacity = '0';
    img.style.transition = 'opacity 0.4s ease';
    if (img.complete) img.style.opacity = '1';
  });
</script>

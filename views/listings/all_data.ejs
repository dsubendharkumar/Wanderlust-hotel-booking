 <% layout("/layouts/boilerplate") %>

<!-- ======= WANDERLUST STYLES ======= -->
<style>
  @import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap');

  :root {
    --primary: #FF385C;
    --primary-dark: #D93B59;
    --dark: #111827;
    --mid: #6B7280;
    --light-bg: #F9FAFB;
    --card-radius: 18px;
    --shadow-soft: 0 4px 24px rgba(0,0,0,0.08);
    --shadow-hover: 0 12px 40px rgba(0,0,0,0.15);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--light-bg);
    color: var(--dark);
  }

  /* ===== CATEGORY ICON BAR ===== */
  .category-bar-wrapper {
    position: sticky;
    top: 0;
    z-index: 100;
    background: #fff;
    border-bottom: 1px solid #e5e7eb;
    box-shadow: 0 2px 12px rgba(0,0,0,0.04);
  }

  .category-bar {
    display: flex;
    align-items: center;
    gap: 0;
    overflow-x: auto;
    scrollbar-width: none;
    padding: 0 24px;
    max-width: 1400px;
    margin: 0 auto;
  }

  .category-bar::-webkit-scrollbar { display: none; }

  .category-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding: 16px 20px;
    cursor: pointer;
    white-space: nowrap;
    border-bottom: 2px solid transparent;
    transition: all 0.22s ease;
    color: var(--mid);
    text-decoration: none;
    min-width: 80px;
    flex-shrink: 0;
  }

  .category-item:hover {
    color: var(--dark);
    border-bottom-color: var(--dark);
  }

  .category-item.active {
    color: var(--dark);
    border-bottom-color: var(--dark);
  }

  .category-item svg,
  .category-item .cat-icon {
    width: 26px;
    height: 26px;
    stroke-width: 1.5;
  }

  .category-item span {
    font-size: 15px;
    font-weight: 500;
    letter-spacing: 0.01em;
  }

  .cat-icon {
    font-size: 15px;
    line-height: 1;
  }

  /* Filter button */
  .filters-btn {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 8px;
    border: 1px solid #D1D5DB;
    border-radius: 12px;
    padding: 10px 16px;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    background: #fff;
    white-space: nowrap;
    transition: box-shadow 0.2s;
    flex-shrink: 0;
    font-family: 'DM Sans', sans-serif;
    color: var(--dark);
  }

  .filters-btn:hover {
    box-shadow: var(--shadow-soft);
  }

  /* ===== HERO SECTION ===== */
  .hero-section {
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
    padding: 60px 24px 80px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .hero-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 30% 60%, rgba(255,56,92,0.18) 0%, transparent 60%),
                radial-gradient(ellipse at 70% 20%, rgba(99,102,241,0.15) 0%, transparent 50%);
  }

  .hero-content { position: relative; z-index: 1; }

  .hero-badge {
    display: inline-block;
    background: rgba(255,56,92,0.15);
    border: 1px solid rgba(255,56,92,0.3);
    color: #FF7B9C;
    padding: 6px 16px;
    border-radius: 100px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 20px;
  }

  .hero-title {
    font-family: 'Syne', sans-serif;
    font-size: clamp(2.2rem, 5vw, 4rem);
    font-weight: 800;
    color: #fff;
    line-height: 1.1;
    margin-bottom: 16px;
  }

  .hero-title span { color: var(--primary); }

  .hero-subtitle {
    color: rgba(255,255,255,0.6);
    font-size: 16px;
    font-weight: 300;
    margin-bottom: 0;
  }

  /* ===== LISTINGS GRID ===== */
  .listings-section {
    max-width: 1400px;
    margin: 0 auto;
    padding: 40px 24px 80px;
  }

  .section-header {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 32px;
  }

  .section-title {
    font-family: 'Syne', sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--dark);
  }

  .section-count {
    font-size: 13px;
    color: var(--mid);
    font-weight: 400;
  }

  .listings-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 28px;
  }

  /* ===== LISTING CARD ===== */
  .listing-card-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .listing-card {
    background: #fff;
    border-radius: var(--card-radius);
    overflow: hidden;
    box-shadow: var(--shadow-soft);
    transition: transform 0.28s cubic-bezier(.25,.8,.25,1), box-shadow 0.28s ease;
    position: relative;
  }

  .listing-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-hover);
  }

  .card-image-wrapper {
    position: relative;
    overflow: hidden;
    height: 220px;
  }

  .card-image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .listing-card:hover .card-image-wrapper img {
    transform: scale(1.07);
  }

  /* Wishlist heart */
  .wishlist-btn {
    position: absolute;
    top: 14px;
    right: 14px;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: rgba(255,255,255,0.88);
    backdrop-filter: blur(6px);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 5;
    transition: all 0.2s;
    box-shadow: 0 2px 8px rgba(0,0,0,0.12);
  }

  .wishlist-btn:hover {
    background: #fff;
    transform: scale(1.1);
  }

  .wishlist-btn svg {
    width: 16px;
    height: 16px;
    stroke: #111;
    stroke-width: 2;
    fill: none;
    transition: all 0.2s;
  }

  .wishlist-btn.liked svg {
    fill: var(--primary);
    stroke: var(--primary);
  }

  /* Rating badge */
  .rating-badge {
    position: absolute;
    bottom: 12px;
    left: 12px;
    background: rgba(0,0,0,0.65);
    backdrop-filter: blur(8px);
    color: #fff;
    padding: 4px 10px;
    border-radius: 100px;
    font-size: 12px;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .rating-badge svg {
    width: 11px;
    height: 11px;
    fill: #FFD700;
    stroke: none;
  }

  /* Image dots */
  .img-dots {
    position: absolute;
    bottom: 12px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 4px;
  }

  .img-dots span {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: rgba(255,255,255,0.5);
  }

  .img-dots span.active {
    background: #fff;
  }

  /* Card body */
  .card-body {
    padding: 16px 18px 18px;
  }

  .card-location {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 11px;
    font-weight: 500;
    color: var(--mid);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 6px;
  }

  .card-location svg {
    width: 12px;
    height: 12px;
    stroke: var(--mid);
    flex-shrink: 0;
  }

  .card-title {
    font-family: 'Syne', sans-serif;
    font-size: 15px;
    font-weight: 700;
    color: var(--dark);
    margin-bottom: 4px;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-distance {
    font-size: 12.5px;
    color: var(--mid);
    margin-bottom: 12px;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 12px;
    border-top: 1px solid #F3F4F6;
  }

  .card-price {
    display: flex;
    align-items: baseline;
    gap: 4px;
  }

  .price-amount {
    font-family: 'Syne', sans-serif;
    font-size: 17px;
    font-weight: 700;
    color: var(--dark);
  }

  .price-unit {
    font-size: 12px;
    color: var(--mid);
    font-weight: 400;
  }

  .card-tag {
    background: #FFF1F3;
    color: var(--primary);
    font-size: 11px;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 100px;
    letter-spacing: 0.03em;
  }

  /* ===== EMPTY STATE ===== */
  .empty-state {
    text-align: center;
    padding: 80px 24px;
    grid-column: 1 / -1;
  }

  .empty-icon {
    font-size: 56px;
    margin-bottom: 16px;
  }

  .empty-state h3 {
    font-family: 'Syne', sans-serif;
    font-size: 1.4rem;
    font-weight: 700;
    margin-bottom: 8px;
  }

  .empty-state p {
    color: var(--mid);
    font-size: 14px;
  }

  /* ===== ANIMATIONS ===== */
  .listing-card-link {
    animation: fadeUp 0.5s ease both;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* stagger children */
  .listings-grid .listing-card-link:nth-child(1) { animation-delay: 0.05s; }
  .listings-grid .listing-card-link:nth-child(2) { animation-delay: 0.10s; }
  .listings-grid .listing-card-link:nth-child(3) { animation-delay: 0.15s; }
  .listings-grid .listing-card-link:nth-child(4) { animation-delay: 0.20s; }
  .listings-grid .listing-card-link:nth-child(5) { animation-delay: 0.25s; }
  .listings-grid .listing-card-link:nth-child(6) { animation-delay: 0.30s; }
  .listings-grid .listing-card-link:nth-child(7) { animation-delay: 0.35s; }
  .listings-grid .listing-card-link:nth-child(8) { animation-delay: 0.40s; }
  .listings-grid .listing-card-link:nth-child(n+9) { animation-delay: 0.45s; }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    .listings-grid {
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 20px;
    }
    .hero-section { padding: 40px 16px 60px; }
    .listings-section { padding: 28px 16px 60px; }
  }

  @media (max-width: 480px) {
    .listings-grid {
      grid-template-columns: 1fr;
    }
    .category-item { padding: 14px 14px; min-width: 68px; }
  }
</style>


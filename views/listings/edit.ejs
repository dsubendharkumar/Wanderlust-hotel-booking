<% layout("/layouts/boilerplate") %>
<body>
<div class="row mt-3" >
    <div class="col-8 offset-2">
    <h2>Edit your list:</h2>

    <form method="post" action="/listings/<%=list._id%>/edit?_method=PUT" novalidate class="needs-validation" >
    
        <div class="mb-3">
        <label for="title" class="form-label" >title</label>
        <input placeholder="enter the title" class="form-control" required  name="title" value="<%=list.title%> "/>
        <div class="valid-feedback">Title looks good!</div>
        </div>

        <div class="mb-3">
        <label for="description" class="form-label"  >description</label>
        <textarea name="description" class="form-control" required  type="text"> <%= list.description %> </textarea>
        <div class="invalid-feedback">Enter the description</div>
        </div>

        <div class="mb-3">
        <label for="image" class="form-label" >image Link</label>
        <input placeholder="enter the url"  class="form-control" required  name="image" type="text" value="<%=list.image%>"/>
        <div class="invalid-feedback">Enter the url of the image</div>
        </div>
        
        <div class="row">
            <div class="mb-3 col-md-4">
            <label for="price" class="form-label" >Price</label>
            <input placeholder="enter the price"  class="form-control"  required name="price"  value="<%= list.price  %>" type="number"/>
            <div class="invalid-feedback">Enter the price</div>
            </div>
            <div class="mb-3 col-md-8">
            <label for="location" class="form-label" >location</label>
            <input placeholder="enter the location" class="form-control" required value="<%=list.location %>" name="location" type="text"/>
            <div class="invalid-feedback">Enter the location</div>
            </div>
        </div>   
        
        <div class="mb-3">
        
        <label for="country" class="form-label" >Country</label>
        <input placeholder="enter the country" class="form-control" required name="country" value="<%=list.country%>" type="text"/>
        <div class="invalid-feedback">Enter the country</div>
        </div>   


        <button class="btn btn-dark mb-3">Edit</button>
    </form>
    </div>
</div>    
</body>

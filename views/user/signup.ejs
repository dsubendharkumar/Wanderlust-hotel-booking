<% layout("/layouts/boilerplate") %>

<div class="row mt-3"  >
    <div class="col-6 offset-3">
        <h1>signup to wanderlust</h1>
        <form action="/signup" method="post" novalidate class="needs-validation" >
            <div class="mb-2">
                <label for="username" class="form-label" >Username</label>
                <input placeholder="enter the username" class="form-control"  name="username" required/>
                <div class="valid-feedback">username looks good!</div>
            </div>
             <div class="mb-2">
                <label for="email" class="form-label" >Email</label>
                <input placeholder="enter the email" class="form-control"  name="email" required/>
                <div class="valid-feedback">good</div>
            </div>
             <div class="mb-2">
                <label for="password" class="form-label" >Password</label>
                <input placeholder="enter the password" class="form-control"  name="password" required/>
                <div class="valid-feedback">password looks good!</div>
            </div>

            <br><br>
            <button class="btn btn-success btn-color ">submit</button>
            <br><br>
        </form>
    
    
    </div>
</div>